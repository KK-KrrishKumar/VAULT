{
  "entities": {
    "company": {
      "title": "Company",
      "description": "Stock representing a listed company on the exchange",
      "type": "object",
      "properties": {
        "symbol": { "type": "string", "description": "Ticker symbol of the company (e.g. AVANTEL)" },
        "name": { "type": "string", "description": "Full name of the company" },
        "marketCap": { "type": "number", "description": "Market capitalization in Crores" },
        "ltp": { "type": "number", "description": "Last traded price in INR" },
        "chg": { "type": "number", "description": "Percentage change" },
        "sector": { "type": "string", "description": "Sector of the industry" },
        "description": { "type": "string", "description": "Brief description of company operations" },
        "logoUrl": { "type": "string" }
      },
      "required": ["symbol", "name", "marketCap", "ltp", "chg", "sector"]
    },
    "financialReport": {
      "title": "Financial Report",
      "description": "Quarterly or annual financial results",
      "type": "object",
      "properties": {
        "symbol": { "type": "string" },
        "companyName": { "type": "string" },
        "period": { "type": "string", "description": "E.g. Q3 FY26" },
        "netProfit": { "type": "number", "description": "Net profit in Crores" },
        "ebitdaMargin": { "type": "number", "description": "EBITDA margin percentage" },
        "revenue": { "type": "number", "description": "Revenue in Crores" },
        "publishedAt": { "type": "string", "format": "date-time" },
        "summary": { "type": "string", "description": "AI-generated or factual summary" }
      },
      "required": ["symbol", "period", "netProfit", "publishedAt"]
    },
    "insiderTrade": {
      "title": "Insider Trade",
      "description": "Acquisitions or sales by promoters/directors",
      "type": "object",
      "properties": {
        "symbol": { "type": "string" },
        "companyName": { "type": "string" },
        "insiderName": { "type": "string" },
        "action": { "type": "string", "description": "Promoter Buying, Promoters Selling, etc." },
        "shares": { "type": "number" },
        "valueCr": { "type": "number", "description": "Value of trade in Crores" },
        "date": { "type": "string" }
      },
      "required": ["symbol", "insiderName", "action", "shares", "date"]
    },
    "pressRelease": {
      "title": "Press Release",
      "description": "Official company announcement",
      "type": "object",
      "properties": {
        "symbol": { "type": "string" },
        "companyName": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "category": { "type": "string" },
        "publishedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["symbol", "title", "publishedAt"]
    },
    "watchlistItem": {
      "title": "Watchlist Item",
      "description": "A user's watched stock",
      "type": "object",
      "properties": {
        "symbol": { "type": "string" },
        "userId": { "type": "string" },
        "addedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["symbol", "userId"]
    },
    "subscriber": {
      "title": "Subscriber",
      "description": "Frictionless WhatsApp subscriber mapping phone to watchlist",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "watchlist": { "type": "array" },
        "isEnabled": { "type": "boolean" },
        "subscribedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "phoneNumber", "watchlist", "isEnabled", "subscribedAt"]
    },
    "whatsappConfig": {
      "title": "WhatsApp Config",
      "description": "WhatsApp notification subscription for a user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "isEnabled": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "phoneNumber", "isEnabled"]
    },
    "whatsappLog": {
      "title": "WhatsApp Log",
      "description": "History of simulated alerts sent to user's WhatsApp",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "symbol": { "type": "string" },
        "type": { "type": "string", "description": "results, insider, press_release, system" },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "message", "timestamp"]
    }
  },
  "firestore": {
    "/companies/{symbol}": {
      "schema": "company",
      "description": "Exchange-listed companies"
    },
    "/financialReports/{reportId}": {
      "schema": "financialReport",
      "description": "Published financial reports"
    },
    "/insiderTrades/{tradeId}": {
      "schema": "insiderTrade",
      "description": "Insider transactions database"
    },
    "/pressReleases/{releaseId}": {
      "schema": "pressRelease",
      "description": "Official company press announcements"
    },
    "/subscribers/{phoneNumber}": {
      "schema": "subscriber",
      "description": "Frictionless subscribers lookup by phone number"
    },
    "/users/{userId}/watchlist/{symbol}": {
      "schema": "watchlistItem",
      "description": "User specific watchlists"
    },
    "/users/{userId}/whatsapp/config": {
      "schema": "whatsappConfig",
      "description": "User's WhatsApp bot configuration"
    },
    "/users/{userId}/whatsappLogs/{logId}": {
      "schema": "whatsappLog",
      "description": "Simulated WhatsApp notifications log"
    }
  }
}
