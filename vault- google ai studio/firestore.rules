rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net: Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Global hardeners and primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 2. Public Read-Only Collections
    match /companies/{symbol} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable server-side or read-only mock
    }

    match /financialReports/{reportId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /insiderTrades/{tradeId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /pressReleases/{releaseId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /subscribers/{phoneNumber} {
      allow get, create, update: if phoneNumber is string 
        && phoneNumber.size() >= 8 
        && phoneNumber.size() <= 20
        && request.resource.data.name is string
        && request.resource.data.phoneNumber == phoneNumber
        && request.resource.data.watchlist is list
        && request.resource.data.isEnabled is bool;
      allow delete: if false;
    }

    // 3. User isolated data with PII isolation & strict schema validations
    match /users/{userId}/watchlist/{symbol} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId)
        && request.resource.data.symbol is string
        && request.resource.data.userId == userId;
      allow delete: if isOwner(userId);
    }

    match /users/{userId}/whatsapp/config {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId)
        && request.resource.data.userId == userId
        && request.resource.data.phoneNumber is string
        && request.resource.data.phoneNumber.size() <= 20
        && request.resource.data.isEnabled is bool;
      allow delete: if isOwner(userId);
    }

    match /users/{userId}/whatsappLogs/{logId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId)
        && request.resource.data.userId == userId
        && request.resource.data.type is string
        && request.resource.data.message is string
        && request.resource.data.message.size() <= 2000;
      allow update, delete: if false; // WhatsApp logs are write-once read-only historical records
    }
  }
}
